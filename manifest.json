{
  "manifest_version": 3,
  "name": "Wishlist Extension",
  "version": "1.0",
  "description": "Wishlist management for Firefox.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WishList"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wishlist-test@example.com"
    }
  }
}
