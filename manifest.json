chrome.runtime.onMessage.addListener((request, sender, sendResponse) => {
  if (request.action === 'addFromPage') {
    chrome.storage.local.get(['wishlist'], (result) => {
      const wishlist = result.wishlist || [];
      
      let hostname = 'Unknown';
      try {
        hostname = new URL(request.pageUrl).hostname;
      } catch (e) { console.error("Invalid URL"); }

      const product = {
        id: Date.now(),
        name: request.productName || 'Unnamed Product',
        price: parseFloat(request.price.replace(/[^0-9.]/g, '')) || 0, // Fix: strip currency symbols
        currency: request.currency || 'USD',
        link: request.pageUrl || '',
        site: hostname,
        image: request.image || '',
        notes: request.notes || '',
        addedDate: new Date().toISOString()
      };

      wishlist.push(product);
      chrome.storage.local.set({ wishlist }, () => {
        sendResponse({ success: true });
      });
    });
    return true; // Keeps the channel open for sendResponse
  }
});
